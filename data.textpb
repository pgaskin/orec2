facilities {
  name: "Terry Fox Athletic Facility"
  description:
    "Track and field complex This outdoor sports facility features an extensive outdoor track and field complex "
    "featuring a lighted, international standard 400-metre polyurethane-surfaced eight-lane running track, along with "
    "multiple throwing and jumping event areas. These include high jump, long jump, javelin, shot put, hammer & "
    "discuss. Sports fields The facility has three lit, premium-classed, grass sports fields, which can be used for a "
    "variety of activities such as soccer, lacrosse, ultimate Frisbee and special events. Mooney's Bay Ski Centre "
    "During the winter, the facility turns into a cross-country ski centre - Mooney's Bay Ski Centre - featuring "
    "five-kilometres of track-set lit trails, for classic and skate-skiing, and includes a ski school for all ages and "
    "abilities."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/terry-fox-athletic-facility"
    _date {
      seconds: 1752022300
    }
  }
  address:
    "2960 Riverside Drive\n"
    "Ottawa ON K1V 8N4\n"
    "Canada"
  _lnglat {
    lng: -75.6923
    lat: 45.37037
  }
  notifications_html:
    "<p> </p>\n"
    "<ul>\n"
    "</ul>\n"
  special_hours_html:
    "<p>The facility is not available on the following dates due to special events:</p>\n"
    "<ul>\n"
    "<li><strong>May 1 to June 25</strong>, Monday to Friday, 8 am to 4 pm</li>\n"
    "<li><strong>May 4 to August 15</strong>, Wednesdays, 5 pm to 10 pm</li>\n"
    "<li><strong>July 29 to August 3</strong>, all day</li>\n"
    "<li><strong>August 30</strong>, all day</li>\n"
    "</ul>\n"
    "<ul>\n"
    "</ul>\n"
}
