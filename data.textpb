facilities {
  name: "Belltown Dome"
  description:
    "Belltown Dome is a covered natural ice pad located in the Britannia area of Bay Ward. In the winter residents can "
    "enjoy ice skating and ice sports. In the summer the arena is used for other sports such as ball hockey and "
    "lacrosse. Schedules are posted below. Ice conditions are weather dependent. Watch this page for updates about "
    "closures during the winter months when fluctuating temperatures impact ice conditions. Belltown Dome is available "
    "to rent. See the Rentals section below."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/belltown-dome"
    _date {
      seconds: 1752022196
    }
  }
  address:
