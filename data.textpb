facilities {
  name: "Fisher Park Community Centre"
  description:
    "Located inside of Fisher Park Public School, the Fisher Park Community Centre boasts all the amenities of a high "
    "school. Our facility includes a full sized gym, a small gym, and numerous classrooms. Fisher Park is the ideal "
    "location for sports, dance classes, meetings, and activities for all ages."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/fisher-park-community-centre"
    _date {
      seconds: 1752022231
    }
  }
  address:
    "250 Holland Avenue\n"
    "Ottawa ON K1Y 0Y5\n"
    "Canada"
  _lnglat {
    lng: -75.73075
    lat: 45.395298
  }
  special_hours_html: "<p>Please contact the facility by phone or email for information on opening hours and washroom availability.</p>\n"
}
facilities {
  name: "Foster Farm Community Centre"
  description:
    "Foster Farm Community Centre has a new look and some new programs for the entire family. We have freshly painted "
    "meeting rooms and a commercial kitchen to host great events, receptions, parties or even community meetings! Come "
    "and check out the 'new' Foster Farm for yourself."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/foster-farm-community-centre"
    _date {
      seconds: 1752022233
    }
  }
  address:
    "1065 Ramsey Crescent\n"
    "Ottawa ON K2B 8A1\n"
    "Canada"
  _lnglat {
    lng: -75.794365
    lat: 45.349796
  }
}
facilities {
  name: "François Dupuis Recreation Centre"
  description:
    "François Dupuis Recreation Centre is a one stop shop for all your fitness needs. We have two beautiful pools: a "
    "25-metre 6 lane pool and a leisure pool, both with ramp entry for easy access plus a dry sauna. Jennifer Stead's "
    "artwork, Water, runs along the pool viewing area. Check out our Fitness and Cardio centre equipped with the "
    "latest technology, including a NuStep machine. We offer a variety of programs for everyone in the family in our "
    "three multipurpose rooms."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/francois-dupuis-recreation-centre"
    _date {
      seconds: 1752022233
    }
  }
  address:
    "2263 Portobello Boulevard\n"
    "Ottawa ON K4A 0X3\n"
    "Canada"
