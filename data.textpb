facilities {
  name: "Glebe Community Centre"
  description:
    "The historic Glebe Community Centre is the perfect location to host meetings, workshops, concerts, weddings, "
    "receptions and special events. Our recently renovated, fully accessible, air conditioned facility has a variety "
    "of amenities which includes a dance/fitness studio, meeting rooms, pottery studio, and our large domed room, "
    "Scotton Hall. Through a partnership with the Glebe Neighbourhood Activities Group the Glebe Community Centre "
    "offers a variety of activities for all ages."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/glebe-community-centre"
    _date {
      seconds: 1752022237
