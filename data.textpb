  name: "Pinhey's Point Historic Site"
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/pinheys-point-historic-site-0"
    _date {
      seconds: 1757623038
    }
  }
  address:
    "270 Pinhey's Point Road\n"
    "Dunrobin ON K0A 1T0\n"
    "Canada"
  special_hours_html:
    "<p>The museum at Pinhey’s Point Historic Site is open to visitors seasonally from May to October. The park is open year-round.</p>\n"
    "<p><strong>Summer season</strong><br/>\n"
    "May 11 – August 31, 2025<br/>\n"
    "Wednesday to Sunday from 10 am to 5 pm</p>\n"
    "<p><strong>Fall season</strong><br/>\n"
    "September 6 – October 12, 2025<br/>\n"
    "Saturday and Sunday from 10 am to 5 pm</p>\n"
}
