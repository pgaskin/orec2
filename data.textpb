facilities {
  name: "Albion-Heatherington Recreation Centre"
  description:
    "The Albion-Heatherington Recreation Centre is a moderately-sized facility featuring a large gym that can be "
    "rented for up to 200 persons for sports, meetings and parties. Our multi-purpose room accommodates up to 60 "
    "people and several smaller rooms are available for meetings. Vision Weave, a set of colourful woven banners, is "
    "on display at the customer service desk."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/albion-heatherington-recreation-centre"
    _date {
      seconds: 1752022188
    }
  }
  address:
    "1560 Heatherington Road\n"
    "Ottawa ON K1V 9P5\n"
    "Canada"
  _lnglat {
    lng: -75.647804
    lat: 45.373203
  }
}
facilities {
  name: "Alexander Community Centre"
  description:
    "The Alexander Community Centre offers a wide range of programs for children, youth and adults. We offer a variety "
    "of rooms to rent, each with a 46 inch flat screen television and surround sound system. Our spacious main hall "
    "seats 100 and has an attached kitchen."
  source {
