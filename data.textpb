facilities {
  name: "Carleton Heights Community Centre"
  description:
    "Located in the heart of the community! We offer a wide selection of recreation activities for preschoolers, "
    "children, adults and older adults. Our programs include morning preschool, play groups, camps, fitness, sports, "
    "arts and much more. We also feature various halls for rent."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/carleton-heights-community-centre"
    _date {
      seconds: 1757622889
    }
  }
  address:
    "1665 Apeldoorn Avenue\n"
    "Ottawa ON K2C 1V6\n"
    "Canada"
  _lnglat {
    lng: -75.702705
    lat: 45.35977
  }
  special_hours_html: "<p><strong>September 1 to 6, closed</strong></p>\n"
