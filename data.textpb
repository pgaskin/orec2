facilities {
  name: "Ron Kolbus Lakeside Centre"
  description:
    "Formerly Lakeside Gardens, the Ron Kolbus Lakeside Centre is situated in west Ottawa's historic Britannia Park, "
    "which provides a beautiful backdrop for your picture-perfect event. Located on 62 acres of picturesque parkland, "
    "the Ron Kolbus Lakeside Centre has a 300-person capacity banquet hall, liquor-licensable patios, and small "
    "meeting rooms."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/ron-kolbus-lakeside-centre"
    _date {
      seconds: 1752022292
    }
  }
  address:
    "102 Greenview Avenue\n"
    "Ottawa ON K2B 8J8\n"
    "Canada"
  _lnglat {
    lng: -75.79647
    lat: 45.362137
  }
}
facilities {
  name: "Routhier Community Centre"
  description:
    "Located in the heart of the Byward Market, this fully accessible, air conditioned facility provides users with a "
    "wide selection of services and amenities including a fitness studio, a sprung floor dance studio, a full size "
    "Gymnasium and comfortable meeting/activity rooms. The Routhier Community Centre is the best kept secret of the "
    "Byward Market Area."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/routhier-community-centre"
