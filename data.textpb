facilities {
  name: "Richelieu Vanier Community Centre"
  description:
    "The Richelieu-Vanier Community Centre is located at 300 des Pères-Blancs Avenue on 10 acres of beautiful parkland "
    "setting. The site offers a variety of services including recreation, cultural and community programming, meeting "
    "room and reception hall rentals, a pétanque and crocket courts and soccer field, the Muséoparc Vanier, the "
    "Action-Vanier Sugar Shack as well as the Vanier Branch of the Ottawa Public Library."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/richelieu-vanier-community-centre"
    _date {
      seconds: 1757623048
    }
  }
  address:
    "300 Des Pères-Blancs Avenue\n"
    "Ottawa ON K1L 7L5\n"
    "Canada"
  _lnglat {
    lng: -75.659996
    lat: 45.4438
  }
  schedule_groups {
    label: "Drop-in schedule - racquet sports"
    _title: "Racquet Sports"
  }
}
