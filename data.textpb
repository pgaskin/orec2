facilities {
  name: "Ottawa South Community Centre"
  description:
    "The Ottawa South Community Centre is nestled in the heart of Old Ottawa South. The centre offers a wide variety "
    "of recreation programs in partnership with the Ottawa South Community Association. Please visit the Old Ottawa "
    "South Community Association website to view their programs. A variety of rooms at Ottawa South Community Centre "
    "can be rented through the City of Ottawa. Whether it is a meeting, children’s birthday party or a small wedding "
    "we can help with your rental needs."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/ottawa-south-community-centre"
    _date {
      seconds: 1752022282
    }
  }
  address:
    "260 Sunnyside Avenue\n"
    "Ottawa ON K1S 0R7\n"
    "Canada"
  _lnglat {
    lng: -75.68178
    lat: 45.39467
  }
  special_hours_html: "<p>Please contact the facility by phone or email for information on opening hours and washroom availability.</p>\n"
}
facilities {
  name: "Overbrook Community Centre"
  description:
    "Newly renovated, this “Green” community facility is located just off the Queensway. The updated building boasts "
    "many environmental design features to create a healthier indoor environment for all our users. Our full size, "
    "sprung, hardwood floor gymnasium and dance studio allow us to offer a wide selection of specialized fitness "
    "programs. Our state of the art media rooms are home to a variety of activities and courses. Looking for a new "
    "venue for your next office event or community meeting? Check out the new Overbrook Community Centre!"
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/overbrook-community-centre"
    _date {
      seconds: 1752022284
    }
  }
  address:
    "33 Quill Street\n"
    "Ottawa ON K1K 4E7\n"
    "Canada"
  _lnglat {
    lng: -75.656845
    lat: 45.425472
  }
