facilities {
  name: "Heron Road Community Centre"
  description:
    "Heron Road Community Centre and Heron Seniors' Centre are located in the heart of the community. We offer a wide "
    "selection of recreational activities for preschoolers to older adults with dance classes, piano lessons, summer "
    "camps, sports, martial arts and fitness classes. Our centre features a full gymnasium, weight and cardio room, "
    "several multi-purpose rooms, a kitchen, a state-of-the-art theatre, and plenty of on-site parking. Floor 3 of the "
    "centre features an 18 foot long curved mural, Home Is Where the Heart Is."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/heron-road-community-centre"
    _date {
      seconds: 1757622949
    }
  }
  address:
    "1480 Heron Road\n"
    "Ottawa ON K1V 6A5\n"
    "Canada"
  _lnglat {
    lng: -75.65436
    lat: 45.37893
  }
  special_hours_html:
    "<ul>\n"
    "<li><strong>The facility is closed until further notice. </strong></li>\n"
    "<li><strong>The cardio and weight room is closed.</strong></li>\n"
    "</ul>\n"
    "<p>We are diligently working to bring our programs and services back to the Heron Road Community Centre. Thank you for your patience as we progress through this transition.</p>\n"
}
facilities {
  name: "Heron Seniors Centre"
  description:
    "Whether you wish to keep in shape, learn a new skill or develop a talent, the Heron Seniors’ Centre has a variety "
    "of recreational programs designed to suit an active adult lifestyle. A professional team of instructors makes the "
    "centre a popular destination for retired or pre-retired adults."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/heron-seniors-centre"
