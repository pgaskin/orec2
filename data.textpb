facilities {
  name: "Kanata Seniors Centre"
  description:
    "The Kanata Seniors’ Centre offers a wide range of recreation programs for adults aged 50 and over. Access to our "
    "services is through membership or program registration. We are located at the rear of the John Mlacak Centre, "
    "which also includes an ice surface, Beaverbrook Library and the Kanata Civic Art Gallery. There is a convenient "
    "drop-off spot directly in front of the main entrance and parking lot to the side."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/kanata-seniors-centre"
    _date {
