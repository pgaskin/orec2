facilities {
  name: "Richcraft Recreation Complex-Kanata"
  description:
    "Located in Kanata North, near the Terry Fox Drive and March Road Intersection, the Richcraft Recreation "
    "Complex-Kanata is Leadership in Energy and Environmental Design certified energy efficient, high quality "
    "recreation/aquatic/fitness facility and community centre.​ The complex is an access point to the Trillium Woods. "
    "The City of Ottawa, in partnership with the Ottawa Mountain Bike Association offers a 15 kilometre multi-use "
    "trail network for hiking and mountain biking, allowing visitors to the woods to experience the beauty of this "
    "natural area."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/richcraft-recreation-complex-kanata"
    _date {
      seconds: 1752022286
    }
  }
  address:
    "4101 Innovation Drive\n"
    "Ottawa ON K2K 0J3\n"
    "Canada"
  _lnglat {
    lng: -75.9305
    lat: 45.340427
  }
  special_hours_html:
