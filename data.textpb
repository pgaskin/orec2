facilities {
  name: "Rideauview Community Centre"
  description:
    "The Rideauview Community Centre is a small centre in the Riverside South Community. It has a small gymnasium, "
    "which is ideal for children's birthday parties and an addition perfect for small receptions. We offer a wide "
    "variety of recreation programs for all ages, stages and interests. We also run programs out of Chapman Mills "
    "Community Building, Claudette Cain Park, and Berrigan Park."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/rideauview-community-centre"
