facilities {
  name: "Westcliffe Community Building"
  description:
    "The Westcliffe Community Building offers City recreation programs, summer camps and is available for private "
    "rentals. It is located in front of a park and there is a small splash on the right-hand side of the building."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/westcliffe-community-building"
    _date {
      seconds: 1752022305
    }
  }
  address:
    "681 Seyton Drive\n"
    "Ottawa ON K2H 1A4\n"
    "Canada"
  _lnglat {
    lng: -75.83525
    lat: 45.315044
  }
  special_hours_html: "<p>Please contact the facility by email for information on opening hours and washroom availability.</p>\n"
}
