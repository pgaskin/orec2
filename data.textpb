facilities {
  name: "Brewer Pool and Arena"
  description:
    "Brewer Pool boasts a 25 metre, six lane pool with a sauna. There is a small lounge with kitchen amenities "
    "available for rent. The arena has one ice surface and the area is home to the outdoor ice oval in winter, weather "
    "permitting."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/brewer-pool-and-arena"
    _date {
      seconds: 1752022200
