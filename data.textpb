facilities {
  name: "Heron Road Community Centre"
  description:
    "Heron Road Community Centre and Heron Seniors' Centre are located in the heart of the community. We offer a wide "
    "selection of recreational activities for preschoolers to older adults with dance classes, piano lessons, summer "
    "camps, sports, martial arts and fitness classes. Our centre features a full gymnasium, weight and cardio room, "
    "several multi-purpose rooms, a kitchen, a state-of-the-art theatre, and plenty of on-site parking. Floor 3 of the "
    "centre features an 18 foot long curved mural, Home Is Where the Heart Is."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/heron-road-community-centre"
    _date {
      seconds: 1752022239
    }
  }
  address:
