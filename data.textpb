facilities {
  name: "Old Town Hall Community Centre"
  description:
    "This beautiful two story heritage building is located near the canal and the University of Ottawa and offers a "
    "full range of programs in cooperation with our community partner, the Community Activities Group (CAG). The "
    "building has a small and medium sized room both with wood sprung floors, perfect for meetings and small "
    "functions. Parking is on street. Accessibility is limited."
  source {
    url: "https://ottawa.ca/en/recreation-and-parks/facilities/place-listing/old-town-hall-community-centre"
    _date {
      seconds: 1752022279
    }
  }
  address:
    "61 Main Street\n"
    "Ottawa ON K1S 1B3\n"
    "Canada"
  special_hours_html: "<p>Please contact the facility by phone or email for information on opening hours and washroom availability.</p>\n"
}
